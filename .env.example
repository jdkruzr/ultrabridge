# Copy to .env (gitignored) and fill in. docker-compose reads .env automatically.

# Bearer token the ub-mcp sidecar uses to authenticate to UltraBridge's API.
# Create one in the UI: Settings → MCP Tokens (shown once at creation).
# Replaces the old UB_MCP_API_USER/UB_MCP_API_PASS basic-auth pair.
UB_MCP_API_TOKEN=
